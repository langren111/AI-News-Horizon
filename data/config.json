{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 3,
    "languages": [
      "en",
      "zh"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "ylecun",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "gabor",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-sdk-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "autogen",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langchain",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 50
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "量子位",
        "url": "https://wechat2rss.xlab.app/feed/7131b577c61365cb47e81000738c10d872685908.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "TechCrunch AI",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "enabled": true,
        "category": "ai-industry"
      },
      {
        "name": "ArXiv CS.AI",
        "url": "https://rss.arxiv.org/rss/cs.AI",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "ai-news"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "OpenAI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": [
        "karpathy",
        "ylecun",
        "AndrewYNg",
        "DrJimFan",
        "oabosta"
      ],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "TypeScript",
        "Rust"
      ],
      "keywords": [
        "llm",
        "ai",
        "agent",
        "rag",
        "gpt",
        "machine learning",
        "deep learning",
        "embedding"
      ],
      "min_stars": 50,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": 30,
    "category_groups": {
      "ai-research": {
        "limit": 8,
        "categories": [
          "ai-research",
          "ai-deepdive"
        ]
      },
      "ai-news": {
        "limit": 8,
        "categories": [
          "ai-news",
          "ai-industry",
          "ai-tools"
        ]
      },
      "ai-image": {
        "limit": 4,
        "categories": [
          "ai-image"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 10
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown"
  }
}